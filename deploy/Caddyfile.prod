{
	admin off
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	reverse_proxy app:8080 {
		health_uri /health
		health_interval 30s
		health_timeout 5s
	}

	encode gzip zstd

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		X-XSS-Protection "1; mode=block"
		Referrer-Policy strict-origin-when-cross-origin
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		Content-Security-Policy "default-src 'self'; script-src 'self' https://checkout.clover.com https://www.google.com/recaptcha/ https://www.gstatic.com/recaptcha/; frame-src 'self' https://checkout.clover.com https://www.google.com/recaptcha/; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.clover.com https://www.google.com/recaptcha/"
	}

	log {
		output stdout
		format json
	}
}
