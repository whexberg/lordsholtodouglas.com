{
	admin off
	local_certs
}

localhost {
	reverse_proxy app:8080 {
		health_uri /health
		health_interval 10s
	}

	encode gzip zstd

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Content-Security-Policy "default-src 'self'; script-src 'self' https://checkout.sandbox.dev.clover.com https://www.google.com/recaptcha/ https://www.gstatic.com/recaptcha/; frame-src 'self' https://checkout.sandbox.dev.clover.com https://www.google.com/recaptcha/; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.clover.com https://www.google.com/recaptcha/"
	}

	log {
		output stdout
		format console
	}
}
